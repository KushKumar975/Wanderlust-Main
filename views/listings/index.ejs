<% layout("/layouts/boilerplate") %>

    <style>
        #filters {
            margin-top: 2rem;
            margin-bottom: 2rem;
            display: flex;
            justify-content: space-evenly;
        }

        .filter {
            border: none;
            text-align: center;

            margin-left: 2rem;
            opacity: 0.7;
        }
        .filter a{
            text-decoration: none;
        }
        .filter:hover {
            opacity: 1;
        }

        .setting {
            border: 2px solid transparent;
            height: 50px;
        }

        .setting:hover {
            border: 2px solid black;
            border-radius: 10px;
            opacity: 1;
        }

        .border1 {
            border: 2px solid transparent;
            padding: 12px 10px 0;
            height: 50px;
            width: 20rem;
            box-sizing: border-box;
        }


        .border1:hover {
            text-align: center;
            border-radius: 10px;
            border: 2px solid black;
        }

        .tax-info {
            display: none;
        }
    </style>

    <body>
        <div id="filters">
        <a href="/category/icons" class="filter">
            <i class="fa-solid fa-ticket-simple"></i>
            <p>icons</p>
        </a>
        <a href="/category/Bed&Breakfast" class="filter">
            <i class="fa-solid fa-mug-hot"></i>
            <p>Bed&Breakfast</p>
        </a>
        <a href="/category/Farm" class="filter">
            <i class="fa-solid fa-cow"></i>
            <p>Farm</p>
        </a>
        <a href="/category/OMG" class="filter">
            <i class="fa-solid fa-satellite"></i>
            <p>OMG!</p>
        </a>
        <a href="/category/Arctic" class="filter">
            <i class="fa-solid fa-snowflake"></i>
            <p>Arctic</p>
        </a>
        <a href="/category/Trending" class="filter">
            <i class="fa-solid fa-fire"></i>
            <p>Trending</p>
        </a>
        <a href="/category/Lake" class="filter">
            <i class="fa-solid fa-water"></i>
            <p>Lake</p>
        </a>
        <a href="/category/Beach" class="filter">
            <i class="fa-solid fa-umbrella-beach"></i>
            <p>Beach</p>
        </a>
            <div class="form-check-reverse border1 filter form-switch">
                <input class="form-check-input" style="margin-right: 3px;"type="checkbox" role="switch" id="flexSwitchCheckDefault">
                <label class="form-check-label" for="flexSwitchCheckDefault">Display Total before taxes</label>
            </div>
            </div>
        <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1">
            <% for(let listing of allListing){ %>
                <a href="/listings/<%= listing._id %>" class="card-link">
                    <div class="card col listing-card">
                        <img class="card-img-top" src="<%= listing.image.url %>" alt="Card image cap" style=" height:
                            18rem;">
                        <div class="card-body">
                            <p class="card-text-title">
                                <%= listing.title%>
                            </p>
                            <!-- <p class="card-text"><%= listing.description%></p> -->
                            <p class="card-text"><i class="fa fa-inr"></i>
                                <%= listing.price.toLocaleString("en-IN")%>/night
                                    <i class="tax-info"> &nbsp; &nbsp; +18% GST</i>
                            </p>
                        </div>
                    </div>
                    <%}%>
        </div>



    </body>


    <script>
        let getswitch = document.getElementById("flexSwitchCheckDefault");

        console.log(getswitch);
        getswitch.addEventListener("click", () => {

            let element = document.getElementsByClassName("tax-info");
            // Iterate over the HTMLCollection


            for (info of element) {
                if (info.style.display != "inline") {
                    info.style.display = "inline";
                } else {
                    info.style.display = "none";
                }


            }

        });


    </script>